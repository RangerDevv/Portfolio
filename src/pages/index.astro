---
import Layout from '../layouts/Layout.astro';
import { caseStudies, portfolioStats, profile, quickFacts, skillGroups } from '../data/site';

const latestStudy = caseStudies[0];
---

<Layout title="RangerDevv | Bento Portfolio" description="A widget-style portfolio for RangerDevv featuring projects, skills, and case studies.">
  <section class="landing-dashboard" aria-label="Portfolio widgets">
    <article class="panel bento-card landing-intro span-7">
      <div class="panel-head">
        <span class="panel-kicker">Overview</span>
        <span class="panel-badge">Contained landing</span>
      </div>
      <h1 class="landing-title">{profile.name}</h1>
      <p class="lede">{profile.title}</p>
      <p>{profile.shortBio}</p>
      <div class="chip-row">
        {skillGroups[0].items.slice(0, 4).map((item) => <span class="chip">{item}</span>)}
        {skillGroups[1].items.slice(0, 3).map((item) => <span class="chip chip-soft">{item}</span>)}
      </div>
      <div class="hero-actions">
        <a class="button" href="/projects">Explore projects</a>
        <a class="button button-secondary" href="/contact">Get in touch</a>
      </div>
    </article>

    <article class="panel bento-card landing-sidebar span-5">
      <div class="panel-head">
        <span class="panel-kicker">At a glance</span>
      </div>
      <div class="compact-stat-grid">
        {portfolioStats.map((stat) => (
          <div class="stat-tile">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="landing-divider"></div>
      <div class="mini-section">
        <h3>Currently learning</h3>
        <ul class="stack-list compact-list">
          {profile.currentlyLearning.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="mini-section">
        <h3>Snapshot</h3>
        <dl class="fact-list compact-facts">
          {quickFacts.slice(0, 3).map((fact) => (
            <div>
              <dt>{fact.label}</dt>
              <dd>{fact.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </article>

    <nav class="landing-nav span-12" aria-label="Landing page navigation">
      <a class="panel bento-card bento-link nav-widget" href="/about">
        <div class="panel-head">
          <span class="panel-kicker">About</span>
          <span class="link-arrow">↗</span>
        </div>
        <h3>Meet the person behind the work.</h3>
        <p>Bio, interests, and what drives the builds.</p>
      </a>

      <a class="panel bento-card bento-link nav-widget" href="/projects">
        <div class="panel-head">
          <span class="panel-kicker">Projects</span>
          <span class="link-arrow">↗</span>
        </div>
        <h3>Browse the full portfolio.</h3>
        <p>Featured work plus the wider archive.</p>
      </a>

      <a class="panel bento-card bento-link nav-widget" href="/skills">
        <div class="panel-head">
          <span class="panel-kicker">Skills</span>
          <span class="link-arrow">↗</span>
        </div>
        <h3>See the stack.</h3>
        <p>{skillGroups[2].items.slice(0, 3).join(' · ')}</p>
      </a>

      <a class="panel bento-card bento-link nav-widget" href="/case-studies">
        <div class="panel-head">
          <span class="panel-kicker">Case studies</span>
          <span class="link-arrow">↗</span>
        </div>
        <h3>Go deeper on selected builds.</h3>
        <p>{latestStudy.title} and other writeups.</p>
      </a>

      <a class="panel bento-card bento-link nav-widget accent-clay" href="/contact">
        <div class="panel-head">
          <span class="panel-kicker">Contact</span>
          <span class="link-arrow">↗</span>
        </div>
        <h3>Reach out fast.</h3>
        <p>Email, GitHub, and the best ways to connect.</p>
      </a>
    </nav>
  </section>
</Layout>
