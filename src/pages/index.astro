---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="RangerDevv | Portfolio">
  <!-- Boot Screen -->
  <div id="boot-screen">
    <div class="boot-content">
      <div class="boot-leaf">
        <svg viewBox="0 0 64 64" fill="none">
          <path class="leaf-body" d="M32 4C32 4 8 20 8 40c0 12 10 20 24 20s24-8 24-20C56 20 32 4 32 4z" fill="#2d5a3d"/>
          <path class="leaf-veins" d="M32 16v40M32 28c-6-2-12 0-14 4M32 36c6-2 12 0 14 4M32 44c-8-2-10 2-12 6" stroke="#faf6ef" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="boot-name">RangerDevv</div>
      <div class="boot-loader">
        <div class="boot-loader-bar"></div>
      </div>
    </div>
  </div>

  <!-- Desktop -->
  <div id="desktop" class="hidden">
    <!-- Wallpaper -->
    <div class="desktop-wallpaper">
      <div class="wp-orb"></div><div class="wp-orb"></div><div class="wp-orb"></div><div class="wp-orb"></div>
      <div class="wp-topo"></div>
      <div class="wp-noise"></div>
    </div>
    <div class="desktop-particles">
      <div class="particle"></div><div class="particle"></div><div class="particle"></div>
      <div class="particle"></div><div class="particle"></div><div class="particle"></div>
    </div>

    <!-- Desktop Widgets -->
    <div id="desktop-widgets">
      <div class="widget widget-clock">
        <div class="widget-time" id="widget-time">12:00</div>
        <div class="widget-date" id="widget-date">Tuesday, April 15</div>
        <div class="widget-greeting" id="widget-greeting">Good afternoon</div>
      </div>
      <div class="widget widget-now-coding">
        <div class="widget-header">
          <span class="widget-dot pulse"></span>
          <span>Now Coding</span>
        </div>
        <div class="widget-track">Portfolio v2.0</div>
        <div class="widget-sub">HTML · CSS · JavaScript</div>
        <div class="widget-bar"><div class="widget-bar-fill"></div></div>
      </div>
      <div class="widget widget-stats">
        <div class="widget-header">
          <span>🌱</span>
          <span>Quick Stats</span>
        </div>
        <div class="widget-stat-row"><span>Repos</span><span class="widget-stat-val">57</span></div>
        <div class="widget-stat-row"><span>Languages</span><span class="widget-stat-val">8+</span></div>
        <div class="widget-stat-row"><span>Streak</span><span class="widget-stat-val">🔥 Active</span></div>
      </div>
      <div class="widget widget-weather">
        <div class="widget-weather-icon">☀️</div>
        <div class="widget-weather-info">
          <div class="widget-weather-temp">24°</div>
          <div class="widget-weather-loc">Earth · Clear</div>
        </div>
      </div>
    </div>

    <!-- Top Bar (macOS style) -->
    <div id="top-bar">
      <div class="top-bar-left">
        <button id="menu-trigger" class="top-bar-item">
          <svg width="16" height="16" viewBox="0 0 64 64" fill="none">
            <path d="M32 4C32 4 8 20 8 40c0 12 10 20 24 20s24-8 24-20C56 20 32 4 32 4z" fill="#2d5a3d"/>
            <path d="M32 16v40M32 28c-6-2-12 0-14 4M32 36c6-2 12 0 14 4" stroke="#faf6ef" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </button>
        <span class="top-bar-item active-app-name" id="active-app-name">Finder</span>
      </div>
      <div class="top-bar-center">
        <span id="top-bar-date"></span>
      </div>
      <div class="top-bar-right">
        <span id="top-bar-clock"></span>
      </div>
    </div>

    <!-- Desktop Icons -->
    <div id="desktop-icons">
      <div class="desktop-icon" data-window="about">
        <div class="icon-img">
          <svg viewBox="0 0 56 56" fill="none">
            <rect width="56" height="56" rx="13" fill="#2d5a3d"/>
            <circle cx="28" cy="21" r="9" fill="#faf6ef"/>
            <path d="M12 48c0-9 7-14 16-14s16 5 16 14" fill="#faf6ef" opacity="0.8"/>
          </svg>
        </div>
        <span>About Me</span>
      </div>
      <div class="desktop-icon" data-window="projects">
        <div class="icon-img">
          <svg viewBox="0 0 56 56" fill="none">
            <rect width="56" height="56" rx="13" fill="#b8860b"/>
            <rect x="10" y="18" width="36" height="26" rx="3" fill="#faf6ef" opacity="0.9"/>
            <rect x="10" y="18" width="36" height="7" rx="3" fill="#d4a843"/>
            <circle cx="16" cy="21.5" r="1.5" fill="#e85d4a"/><circle cx="21" cy="21.5" r="1.5" fill="#f5b731"/><circle cx="26" cy="21.5" r="1.5" fill="#2d5a3d"/>
          </svg>
        </div>
        <span>Projects</span>
      </div>
      <div class="desktop-icon" data-window="skills">
        <div class="icon-img">
          <svg viewBox="0 0 56 56" fill="none">
            <rect width="56" height="56" rx="13" fill="#3a7d4e"/>
            <path d="M16 38V28M23 38V22M30 38V30M37 38V26" stroke="#faf6ef" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </div>
        <span>Skills</span>
      </div>
      <div class="desktop-icon" data-window="contact">
        <div class="icon-img">
          <svg viewBox="0 0 56 56" fill="none">
            <rect width="56" height="56" rx="13" fill="#c4956a"/>
            <rect x="10" y="16" width="36" height="24" rx="4" fill="#faf6ef"/>
            <path d="M10 20l18 11 18-11" stroke="#c4956a" stroke-width="2.5"/>
          </svg>
        </div>
        <span>Contact</span>
      </div>
      <div class="desktop-icon" data-window="terminal">
        <div class="icon-img">
          <svg viewBox="0 0 56 56" fill="none">
            <rect width="56" height="56" rx="13" fill="#1a2e1a"/>
            <path d="M16 22l10 7-10 7" stroke="#5cb87a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="30" y1="36" x2="40" y2="36" stroke="#5cb87a" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </div>
        <span>Terminal</span>
      </div>
      <!-- Cute spacer smiley -->
      <div class="desktop-mascot-mini">
        <svg viewBox="0 0 32 32" width="32" height="32">
          <circle cx="16" cy="16" r="14" fill="#5cb87a" opacity="0.15"/>
          <circle cx="11" cy="13" r="2" fill="#2d5a3d"/>
          <circle cx="21" cy="13" r="2" fill="#2d5a3d"/>
          <path d="M10 19c2 4 10 4 12 0" stroke="#2d5a3d" stroke-width="1.8" stroke-linecap="round" fill="none"/>
          <ellipse cx="7" cy="18" rx="2" ry="1.2" fill="#c4956a" opacity="0.4"/>
          <ellipse cx="25" cy="18" rx="2" ry="1.2" fill="#c4956a" opacity="0.4"/>
        </svg>
      </div>
      <div class="desktop-icon" data-window="casestudies">
        <div class="icon-img">
          <svg viewBox="0 0 56 56" fill="none">
            <rect width="56" height="56" rx="13" fill="#1e3f2b"/>
            <rect x="12" y="10" width="32" height="36" rx="3" fill="#faf6ef" opacity="0.9"/>
            <rect x="17" y="17" width="18" height="2" rx="1" fill="#2d5a3d" opacity="0.6"/>
            <rect x="17" y="22" width="22" height="2" rx="1" fill="#2d5a3d" opacity="0.4"/>
            <rect x="17" y="27" width="14" height="2" rx="1" fill="#2d5a3d" opacity="0.3"/>
            <rect x="17" y="34" width="20" height="2" rx="1" fill="#2d5a3d" opacity="0.4"/>
            <rect x="17" y="39" width="10" height="2" rx="1" fill="#2d5a3d" opacity="0.3"/>
          </svg>
        </div>
        <span>Case Studies</span>
      </div>
    </div>

    <!-- Cat on a bike mascot -->
    <div class="desktop-mascot" id="desktop-mascot" title="meow :3">
      <svg viewBox="0 0 120 100" fill="none">
        <!-- Bike wheels -->
        <circle cx="30" cy="78" r="16" stroke="#6b5b47" stroke-width="2.5" fill="none"/>
        <circle cx="90" cy="78" r="16" stroke="#6b5b47" stroke-width="2.5" fill="none"/>
        <!-- Wheel spokes -->
        <line x1="30" y1="62" x2="30" y2="94" stroke="#6b5b47" stroke-width="1" opacity="0.4"/>
        <line x1="14" y1="78" x2="46" y2="78" stroke="#6b5b47" stroke-width="1" opacity="0.4"/>
        <line x1="19" y1="67" x2="41" y2="89" stroke="#6b5b47" stroke-width="1" opacity="0.4"/>
        <line x1="41" y1="67" x2="19" y2="89" stroke="#6b5b47" stroke-width="1" opacity="0.4"/>
        <line x1="90" y1="62" x2="90" y2="94" stroke="#6b5b47" stroke-width="1" opacity="0.4"/>
        <line x1="74" y1="78" x2="106" y2="78" stroke="#6b5b47" stroke-width="1" opacity="0.4"/>
        <!-- Bike frame -->
        <path d="M30 78L55 55L90 78L55 55L55 75" stroke="#2d5a3d" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M55 75L30 78" stroke="#2d5a3d" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Handlebars -->
        <path d="M87 68Q90 60 95 62" stroke="#2d5a3d" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Seat -->
        <rect x="50" y="52" width="12" height="4" rx="2" fill="#6b5b47"/>
        <!-- Cat body -->
        <ellipse cx="56" cy="42" rx="14" ry="12" fill="#c4956a"/>
        <!-- Cat head -->
        <circle cx="56" cy="26" r="12" fill="#c4956a"/>
        <!-- Cat ears -->
        <path d="M47 18L44 7L52 15Z" fill="#c4956a"/>
        <path d="M65 18L68 7L60 15Z" fill="#c4956a"/>
        <path d="M48 17L45.5 9L52 15Z" fill="#e8c9a8" opacity="0.5"/>
        <path d="M64 17L66.5 9L60 15Z" fill="#e8c9a8" opacity="0.5"/>
        <!-- Cat face -->
        <circle cx="51" cy="24" r="2" fill="#2d5a3d"/>
        <circle cx="61" cy="24" r="2" fill="#2d5a3d"/>
        <circle cx="51.8" cy="23.3" r="0.7" fill="#faf6ef"/>
        <circle cx="61.8" cy="23.3" r="0.7" fill="#faf6ef"/>
        <!-- Cat nose & mouth -->
        <ellipse cx="56" cy="28" rx="1.5" ry="1" fill="#e8a0a0"/>
        <path d="M56 29Q53 32 50 30" stroke="#2d5a3d" stroke-width="0.8" fill="none" stroke-linecap="round"/>
        <path d="M56 29Q59 32 62 30" stroke="#2d5a3d" stroke-width="0.8" fill="none" stroke-linecap="round"/>
        <!-- Whiskers -->
        <line x1="42" y1="26" x2="49" y2="27" stroke="#2d5a3d" stroke-width="0.7" opacity="0.5"/>
        <line x1="42" y1="29" x2="49" y2="29" stroke="#2d5a3d" stroke-width="0.7" opacity="0.5"/>
        <line x1="70" y1="26" x2="63" y2="27" stroke="#2d5a3d" stroke-width="0.7" opacity="0.5"/>
        <line x1="70" y1="29" x2="63" y2="29" stroke="#2d5a3d" stroke-width="0.7" opacity="0.5"/>
        <!-- Cat paws on handlebars -->
        <circle cx="90" cy="65" r="4" fill="#c4956a"/>
        <circle cx="55" cy="53" r="3.5" fill="#c4956a"/>
        <!-- Tail -->
        <path d="M42 42Q30 30 28 38Q26 46 35 44" stroke="#c4956a" stroke-width="4" stroke-linecap="round" fill="none"/>
        <!-- Blush -->
        <ellipse cx="47" cy="29" rx="3" ry="1.5" fill="#e8a0a0" opacity="0.3"/>
        <ellipse cx="65" cy="29" rx="3" ry="1.5" fill="#e8a0a0" opacity="0.3"/>
        <!-- Helmet -->
        <path d="M44 20Q44 10 56 8Q68 10 68 20" stroke="#2d5a3d" stroke-width="2" fill="#5cb87a" opacity="0.7"/>
        <line x1="44" y1="20" x2="68" y2="20" stroke="#2d5a3d" stroke-width="1.5"/>
      </svg>
      <span class="mascot-label">meow :3</span>
    </div>

    <!-- Windows Container -->
    <div id="windows-container">
      <!-- About Me Window -->
      <div class="window" id="window-about" style="display:none;">
        <div class="window-titlebar">
          <div class="window-controls">
            <button class="win-btn close" title="Close"></button>
            <button class="win-btn minimize" title="Minimize"></button>
            <button class="win-btn maximize" title="Maximize"></button>
          </div>
          <div class="window-title">About Me</div>
          <div class="window-controls-spacer"></div>
        </div>
        <div class="window-content">
          <div class="about-container">

            <!-- Section 1: Hero -->
            <section class="about-section about-hero-section">
              <div class="about-hero">
                <div class="about-avatar-wrap">
                  <img src="https://avatars.githubusercontent.com/u/66392962?v=4" alt="RangerDevv" class="about-avatar" />
                  <div class="avatar-status">
                    <span class="status-dot"></span>
                  </div>
                </div>
                <div class="about-intro">
                  <h1 class="reveal-text">RangerDevv</h1>
                  <p class="about-role">Full-Stack Developer · Open Source Builder</p>
                  <div class="about-location">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>Earth · he/him</span>
                  </div>
                </div>
              </div>
              <div class="about-stats">
                <div class="stat" data-count="57"><span class="stat-num">0</span><span class="stat-label">Repos</span></div>
                <div class="stat" data-count="339"><span class="stat-num">0</span><span class="stat-label">Contributions</span></div>
                <div class="stat" data-count="13"><span class="stat-num">0</span><span class="stat-label">Followers</span></div>
              </div>
            </section>

            <!-- Section 2: Bio -->
            <section class="about-section fade-in-section">
              <div class="about-section-header">
                <span class="section-icon">📄</span>
                <h2>readme.md</h2>
              </div>
              <div class="about-bio">
                <p>Hi! The name's Ranger... RangerDevv specifically. Don't ask me about the extra v, I couldn't tell you why it's there in the first place either.</p>
                <p>I love learning new stuff, currently interested in learning <strong>Rust</strong> and building software with it. I also love making websites with <strong>Svelte</strong>, <strong>Astro</strong>, and <strong>TailwindCSS</strong>.</p>
                <p>When I'm not coding, you'll probably find me <strong>mountain biking</strong> through trails or hanging out with my cat. Life's about balance, right? 🚵</p>
              </div>
            </section>

            <!-- Section 3: Quick Stack -->
            <section class="about-section fade-in-section">
              <div class="about-section-header">
                <span class="section-icon">⚡</span>
                <h2>Tech I Love</h2>
              </div>
              <div class="about-stack-grid">
                <div class="stack-chip" style="--chip-color:#ff3e00"><span class="stack-chip-dot" style="background:#ff3e00"></span>Svelte</div>
                <div class="stack-chip" style="--chip-color:#bc52ee"><span class="stack-chip-dot" style="background:#bc52ee"></span>Astro</div>
                <div class="stack-chip" style="--chip-color:#06b6d4"><span class="stack-chip-dot" style="background:#06b6d4"></span>Tailwind</div>
                <div class="stack-chip" style="--chip-color:#f7df1e"><span class="stack-chip-dot" style="background:#f7df1e"></span>JavaScript</div>
                <div class="stack-chip" style="--chip-color:#3178c6"><span class="stack-chip-dot" style="background:#3178c6"></span>TypeScript</div>
                <div class="stack-chip" style="--chip-color:#dea584"><span class="stack-chip-dot" style="background:#dea584"></span>Rust</div>
                <div class="stack-chip" style="--chip-color:#3776ab"><span class="stack-chip-dot" style="background:#3776ab"></span>Python</div>
                <div class="stack-chip" style="--chip-color:#2b3137"><span class="stack-chip-dot" style="background:#2b3137"></span>Node.js</div>
              </div>
              <button class="about-more-btn" onclick="openWindow('window-skills')">
                See all skills
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </section>

            <!-- Section 4: Interests -->
            <section class="about-section fade-in-section">
              <div class="about-section-header">
                <span class="section-icon">🌿</span>
                <h2>Beyond the Code</h2>
              </div>
              <div class="about-interests">
                <div class="interest-card">
                  <div class="interest-emoji">🐱</div>
                  <div class="interest-info">
                    <strong>Cat Person</strong>
                    <span>Proud cat parent. My cat is my unofficial pair programmer — mostly supervises from the keyboard.</span>
                  </div>
                </div>
                <div class="interest-card">
                  <div class="interest-emoji">🚵</div>
                  <div class="interest-info">
                    <strong>Mountain Biking</strong>
                    <span>Nothing beats hitting the trails. Keeps me sane when the code won't compile.</span>
                  </div>
                </div>
                <div class="interest-card">
                  <div class="interest-emoji">🌱</div>
                  <div class="interest-info">
                    <strong>Always Learning</strong>
                    <span>Currently deep-diving into Rust. Previously survived the JavaScript framework wars.</span>
                  </div>
                </div>
              </div>
            </section>

            <!-- Section 5: Quick Facts -->
            <section class="about-section fade-in-section">
              <div class="about-section-header">
                <span class="section-icon">📋</span>
                <h2>Quick Facts</h2>
              </div>
              <div class="about-facts">
                <div class="fact-row"><span class="fact-label">🎂 Age</span><span class="fact-value">17</span></div>
                <div class="fact-row"><span class="fact-label">🎓 Studying</span><span class="fact-value">Penn State University — Freshman</span></div>
                <div class="fact-row"><span class="fact-label">📍 Location</span><span class="fact-value">Earth</span></div>
                <div class="fact-row"><span class="fact-label">💻 Focus</span><span class="fact-value">Full-Stack Web Dev & Open Source</span></div>
                <div class="fact-row"><span class="fact-label">🗣️ Languages</span><span class="fact-value">English, Uzbek</span></div>
                <div class="fact-row"><span class="fact-label">☕ Status</span><span class="fact-value">Open to collaborate</span></div>
              </div>
            </section>

            <!-- Section 6: CTA -->
            <section class="about-section about-cta-section fade-in-section">
              <div class="about-cta-card">
                <p>Want to see what I've built?</p>
                <div class="about-cta-buttons">
                  <button class="cta-btn" onclick="openWindow('window-projects')">
                    <span>Explore my projects</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                  <button class="cta-btn cta-btn-secondary" onclick="openWindow('window-contact')">
                    <span>Get in touch</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                </div>
              </div>
            </section>

          </div>
        </div>
      </div>

      <!-- Projects Window -->
      <div class="window wide-window" id="window-projects" style="display:none;">
        <div class="window-titlebar">
          <div class="window-controls">
            <button class="win-btn close" title="Close"></button>
            <button class="win-btn minimize" title="Minimize"></button>
            <button class="win-btn maximize" title="Maximize"></button>
          </div>
          <div class="window-title">Projects</div>
          <div class="window-controls-spacer"></div>
        </div>
        <div class="window-body-split">
          <div class="window-sidebar">
            <h3>Favorites</h3>
            <button class="sidebar-btn active" data-category="pinned">📌 Pinned</button>
            <button class="sidebar-btn" data-category="web">🌐 Web Apps</button>
            <button class="sidebar-btn" data-category="tools">🔧 Tools</button>
            <button class="sidebar-btn" data-category="ai">🤖 AI / ML</button>
            <h3>Library</h3>
            <button class="sidebar-btn" data-category="all">📁 All Projects</button>
            <button class="sidebar-btn" data-category="games">🎮 Games</button>
            <div class="sidebar-nav-divider"></div>
            <button class="sidebar-nav-link" onclick="openWindow('window-skills')">
              <span>⚡ My Skills</span>
              <span class="nav-arrow">→</span>
            </button>
            <button class="sidebar-nav-link" onclick="openWindow('window-casestudies')">
              <span>📝 Case Studies</span>
              <span class="nav-arrow">→</span>
            </button>
          </div>
          <div class="window-main">
            <div class="projects-grid" id="projects-grid"></div>
          </div>
        </div>
      </div>

      <!-- Skills Window -->
      <div class="window" id="window-skills" style="display:none;">
        <div class="window-titlebar">
          <div class="window-controls">
            <button class="win-btn close" title="Close"></button>
            <button class="win-btn minimize" title="Minimize"></button>
            <button class="win-btn maximize" title="Maximize"></button>
          </div>
          <div class="window-title">Skills</div>
          <div class="window-controls-spacer"></div>
        </div>
        <div class="window-content">
          <div class="skills-container">
            <div class="skill-section fade-in-section">
              <h3>Languages</h3>
              <div class="skills-row">
                <div class="skill-pill" style="--pill-color:#f7df1e;--fill:90%"><div class="pill-icon" style="background:#f7df1e;color:#1a1a1a;">JS</div><span>JavaScript</span><div class="pill-bar"><div class="pill-fill"></div></div></div>
                <div class="skill-pill" style="--pill-color:#3178c6;--fill:85%"><div class="pill-icon" style="background:#3178c6;">TS</div><span>TypeScript</span><div class="pill-bar"><div class="pill-fill"></div></div></div>
                <div class="skill-pill" style="--pill-color:#3776ab;--fill:80%"><div class="pill-icon" style="background:#3776ab;">Py</div><span>Python</span><div class="pill-bar"><div class="pill-fill"></div></div></div>
