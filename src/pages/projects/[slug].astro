---
import Layout from '../../layouts/Layout.astro';
import { featuredProjects, getProjectBySlug } from '../../data/site';

export function getStaticPaths() {
  return featuredProjects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug ?? '');

if (!project) {
  throw new Error(`Unknown project slug: ${slug}`);
}
---

<Layout title={`${project.name} | RangerDevv`} description={project.summary}>
  <section class="page-hero">
    <div>
      <span class="eyebrow">{project.category}</span>
      <h1>{project.name}</h1>
      <p class="lede">{project.tagline}</p>
      <p>{project.summary}</p>
    </div>
    <div class="hero-actions">
      {project.links.map((link) => (
        <a
          class:list={{
            button: true,
            'button-secondary': !link.external,
          }}
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
  </section>

  <section class="content-grid">
    <article class="panel content-card span-8">
      <div class="panel-head">
        <span class="panel-kicker">Challenge</span>
      </div>
      <p>{project.challenge}</p>
      <div class="spacer"></div>
      <div class="panel-head">
        <span class="panel-kicker">Solution</span>
      </div>
      <p>{project.solution}</p>
    </article>

    <article class="panel content-card span-4">
      <div class="panel-head">
        <span class="panel-kicker">Project signals</span>
      </div>
      <div class="stat-grid">
        {project.metrics.map((metric) => (
          <div class="stat-tile">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
    </article>

    <article class="panel content-card span-6">
      <div class="panel-head">
        <span class="panel-kicker">Stack</span>
      </div>
      <div class="chip-row">
        {project.stack.map((item) => <span class="chip">{item}</span>)}
      </div>
    </article>

    <article class="panel content-card span-6">
      <div class="panel-head">
        <span class="panel-kicker">Highlights</span>
      </div>
      <ul class="stack-list">
        {project.highlights.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="panel content-card span-12">
      <div class="panel-head">
        <span class="panel-kicker">What I learned</span>
      </div>
      <div class="three-up">
        {project.learnings.map((item) => (
          <div class="value-card">
            <p>{item}</p>
          </div>
        ))}
      </div>
    </article>
  </section>
</Layout>
